DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/discord_live_watcher?schema=public"

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Legacy/shared interval. Twitch will use this if TWITCH_WATCH_INTERVAL_MS is not set.
WATCH_INTERVAL_MS=60000
TWITCH_WATCH_INTERVAL_MS=60000

# TikTok watcher tuning
TIKTOK_DAILY_BUDGET=700
TIKTOK_MIN_INTERVAL_MINUTES=2
TIKTOK_MAX_INTERVAL_MINUTES=30
TIKTOK_IDLE_INTERVAL_MS=300000
TIKTOK_RATE_LIMIT_BACKOFF_MS=1800000
TIKTOK_PER_STREAMER_DELAY_MS=1500
TIKTOK_OVERLAP_RETRY_MS=60000
TIKTOK_FAILURE_RETRY_MS=300000
