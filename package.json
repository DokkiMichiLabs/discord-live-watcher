{
  "name": "discord-live-watcher",
  "version": "1.0.0",
  "description": "Discord bot that watches Twitch and TikTok live status and posts notifications.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
